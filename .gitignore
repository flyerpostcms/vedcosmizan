# ─────────────────────────────────────────────────────────────
# VedCosmizan .gitignore
# Keeps your private things OFF the public GitHub repo.
# (AGPL only needs your CODE public — NOT your database or keys.)
# Replace the .gitignore that `flutter create` made with this file.
# ─────────────────────────────────────────────────────────────

# ===== YOUR MOAT — prediction database stays private =====
assets/db/*.sqlite
assets/db/*.db

# ===== SECRETS — never upload =====
.env
.env.*
lib/config/supabase_keys.dart
lib/config/ai_keys.dart

# ===== ANDROID SIGNING — VERY important to keep private =====
*.jks
*.keystore
android/key.properties
android/app/upload-keystore.jks

# ===== Flutter / Dart =====
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds

# ===== IDE / editor =====
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store

# ===== Android =====
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties

# ===== iOS (for later, when you get a Mac) =====
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/.symlinks/
**/ios/Pods/
**/ios/.generated/

# ===== Misc =====
*.log
*.lock.bak
coverage/
